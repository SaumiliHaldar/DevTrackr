// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Each user has exactly ONE row.
model User {
  id           String       @id @default(cuid())
  clerkId      String       @unique
  githubHandle String?      @unique
  email        String       @unique
  name         String?
  avatarUrl    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // One-to-one relations — every user has one row in each of these tables
  repositories Repository?
  commits      Commit?
  pullRequests PullRequest?
  insights     Insight[]
}

// Each user has exactly ONE row here.
// `repositoriesData` is a JSON array of all their repos.
// e.g. [{ "githubId": 123, "name": "my-repo", "language": "Python", ... }, ...]
model Repository {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  repositoriesData Json     @default("[]")
  updatedAt        DateTime @updatedAt
}

// Each user has exactly ONE row here.
// `commitsData` is a JSON array of all their commits across ALL repos.
// e.g. [{ "sha": "abc", "message": "fix bug", "date": "...", "repoName": "my-repo", "additions": 5, "deletions": 2 }, ...]
model Commit {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  commitsData Json     @default("[]")
  updatedAt   DateTime @updatedAt
}

// Each user has exactly ONE row here.
// `pullRequestsData` is a JSON array of all their PRs across ALL repos.
// e.g. [{ "githubId": 456, "title": "Add feature", "state": "merged", "repoName": "my-repo", ... }, ...]
model PullRequest {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  pullRequestsData Json     @default("[]")
  updatedAt        DateTime @updatedAt
}

model Insight {
  id        String   @id @default(cuid())
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
